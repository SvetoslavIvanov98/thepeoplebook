PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/social_db

# DB pool tuning (optional)
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=5000

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Frontend URL (for CORS & OAuth redirects)
FRONTEND_URL=http://localhost:5173

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Redis (optional — gracefully degrades if unavailable)
REDIS_URL=redis://localhost:6379

# Admin (optional — auto-promotes this username to admin on startup)
ADMIN_USERNAME=

# Error Tracking
SENTRY_DSN=

# Web Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Email (Resend — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=hello@thepeoplebook.net
